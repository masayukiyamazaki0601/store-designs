---
import siteData from '../data/site.json';
---

<section id="menu">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <span class="tag">02 — MENU & PRICE</span>
        <h2>MENU</h2>
      </div>
      <p class="head-note">技術に対する対価。料金はすべて税込表示。</p>
    </div>
    <div class="menu-grid reveal">
      {siteData.menuList.map((item: any) => (
        <div class="menu-card">
          <div>
            <span class="cat">{item.cat}</span>
            <h3>{item.name}</h3>
            <p class="desc">{item.desc}</p>
          </div>
          <div class="price">{item.price}<span> {item.unit}</span></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .menu-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .menu-card { background: var(--black); padding: 28px 24px; display: flex; flex-direction: column; justify-content: space-between; transition: background .3s; }
  .menu-card:hover { background: var(--panel); }
  .menu-card .cat { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--brass); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 8px; display: inline-block; }
  .menu-card h3 { font-size: 20px; margin-bottom: 4px; }
  .menu-card .desc { color: var(--ash); font-size: 12px; font-weight: 300; margin-bottom: 14px; }
  .menu-card .price { font-family: 'Oswald', sans-serif; font-size: 22px; color: var(--cream-dim); }
  .menu-card .price span { font-size: 12px; color: var(--ash); }

  @media (max-width: 900px) {
    .menu-grid { grid-template-columns: 1fr; }
  }
</style>

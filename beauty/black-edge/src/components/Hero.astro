---
import siteData from '../data/site.json';
---

<section id="top" class="hero">
  <div class="hero-bg" id="heroBg" style={`background-image: url('${siteData.heroImage}')`}></div>
  <div class="hero-inner">
    <span class="eyebrow mono">{siteData.tagline}</span>
    <h1>SHARP.<br>EDGE.<br><span class="outline">STYLE.</span></h1>
    <p class="hero-sub">{siteData.catchphrase} 一人ひとりの骨格・髪質・ライフスタイルに合わせたデザインを、熟練のスタイリストが提案する。</p>
    <div class="btn-row">
      <a href="#reserva" class="btn solid">Reserve</a>
      <a href="#menu" class="btn outline">View Menu</a>
    </div>
  </div>
  <div class="hero-badge">
    <div class="num">{siteData.heroBadgeNum}</div>
    <div class="label">{siteData.heroBadgeLabel}</div>
  </div>
  <div class="scroll-cue"><div class="scroll-line"></div>SCROLL</div>
</section>

<style>
  .hero { min-height: 100vh; position: relative; display: flex; align-items: center; overflow: hidden; border-bottom: 1px solid var(--line); }
  .hero-bg {
    position: absolute; inset: -10%;
    background-size: cover; background-position: center 35%; background-repeat: no-repeat;
    will-change: transform;
  }
  .hero-bg::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,9,8,0.7) 0%, rgba(10,9,8,0.95) 100%);
  }
  .hero-inner { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; width: 100%; padding: 0 28px; padding-top: 80px; }
  .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.3em; color: var(--brass); margin-bottom: 20px; display: flex; align-items: center; gap: 12px; }
  .eyebrow::before { content: ""; width: 28px; height: 1px; background: var(--brass); }
  .hero h1 { font-size: clamp(48px, 10vw, 150px); color: var(--cream); margin-bottom: 4px; line-height: 0.95; }
  .hero h1 .outline { color: transparent; -webkit-text-stroke: 1.5px var(--cream); }
  .hero-sub { max-width: 500px; color: var(--cream-dim); font-size: 15px; margin: 22px 0 32px; font-weight: 300; line-height: 1.7; }
  .btn-row { display: flex; gap: 14px; flex-wrap: wrap; }

  .hero-badge {
    position: absolute; right: 5%; bottom: 12%; z-index: 3;
    background: rgba(10,9,8,0.75); backdrop-filter: blur(8px);
    border: 1px solid var(--line-strong); padding: 20px 24px; max-width: 200px;
    animation: float 5s ease-in-out infinite;
  }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .hero-badge .num { font-family: 'Oswald', sans-serif; font-size: 34px; color: var(--brass); line-height: 1; }
  .hero-badge .label { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--ash); letter-spacing: 0.1em; margin-top: 4px; }
  @media (max-width: 900px) { .hero-badge { display: none; } }

  .scroll-cue { position: absolute; bottom: 28px; left: 28px; z-index: 3; display: flex; align-items: center; gap: 8px; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--ash); letter-spacing: 0.15em; }
  .scroll-line { width: 1px; height: 32px; background: var(--ash); position: relative; overflow: hidden; }
  .scroll-line::after { content: ""; position: absolute; top: -100%; left: 0; width: 100%; height: 100%; background: var(--brass); animation: scrolldrop 1.8s ease-in-out infinite; }
  @keyframes scrolldrop { to { top: 100%; } }

  @media (max-width: 900px) {
    .hero-inner { padding-top: 40px; }
    .hero h1 { font-size: clamp(48px, 16vw, 80px); }
    .hero-sub { font-size: 14px; margin: 16px 0 24px; }
    .btn-row { flex-direction: column; width: 100%; max-width: 320px; }
    .btn-row .btn { text-align: center; }
    .hero-badge { display: none; }
  }
</style>

---
import siteData from '../data/site.json';
---

<section id="concept">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <span class="tag">01 — CONCEPT</span>
        <h2 set:html={siteData.conceptTitle}></h2>
      </div>
      <p class="head-note">{siteData.conceptNote}</p>
    </div>
    <div class="concept-grid">
      <div class="concept-img reveal">
        <img src="/images/concept.jpg" alt="店内の様子" loading="lazy">
        <span class="badge mono">EST. 2016</span>
      </div>
      <div class="reveal">
        <div class="concept-text">
          {siteData.conceptDesc.map((desc: string) => (
            <p>{desc}</p>
          ))}
        </div>
        <div class="stat-row reveal">
          {siteData.stats.map((stat: any) => (
            <div class="stat">
              <div class="num">{stat.num}</div>
              <div class="label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .concept-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .concept-img { position: relative; aspect-ratio: 4/5; overflow: hidden; border: 1px solid var(--line); }
  .concept-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .7s ease; }
  .concept-img:hover img { transform: scale(1.05); }
  .concept-img .badge { position: absolute; top: 14px; left: 14px; font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; color: var(--black); background: var(--brass); padding: 4px 10px; font-weight: 700; }
  .concept-text p { color: var(--cream-dim); margin-bottom: 18px; font-size: 15px; max-width: 460px; font-weight: 300; }
  
  .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; margin-top: 44px; border-top: 1px solid var(--line); }
  .stat { padding: 24px 20px 0; }
  .stat .num { font-family: 'Oswald', sans-serif; font-size: 38px; color: var(--brass); line-height: 1; }
  .stat .label { font-size: 10px; color: var(--ash); font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em; margin-top: 4px; }

  @media (max-width: 900px) {
    .concept-grid { grid-template-columns: 1fr; }
    .stat-row { grid-template-columns: 1fr; }
    .stat { border-bottom: 1px solid var(--line); padding-bottom: 16px; }
  }
</style>

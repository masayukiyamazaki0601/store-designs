---
import siteData from '../data/site.json';
---

<section id="staff">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <span class="tag">04 — TEAM</span>
        <h2>STAFF</h2>
      </div>
      <p class="head-note">技術とホスピタリティ。それぞれのスタイリストがプロとして向き合う。</p>
    </div>
    <div class="staff-grid reveal">
      {siteData.staffList.map((staff: any) => (
        <div class="staff-card">
          <div class="staff-inner">
            <div class="staff-photo" style={`background:url('${staff.image}') center/cover`}>
              <span class="id">{staff.id}</span>
              <span class="role-badge">{staff.roleBadge}</span>
            </div>
            <span class="staff-role">{staff.role}</span>
            <h3 class="staff-name">{staff.name}</h3>
            <p class="staff-bio">{staff.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .staff-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .staff-card { background: var(--black); overflow: hidden; }
  .staff-inner { padding: 28px 22px; }
  .staff-photo { width: 100%; aspect-ratio: 1/1; background: linear-gradient(145deg, #1f1c18, #0a0908); border: 1px solid var(--line); margin-bottom: 16px; position: relative; overflow: hidden; }
  .staff-photo .role-badge { position: absolute; top: 10px; right: 10px; background: var(--brass); color: var(--black); font-family: 'JetBrains Mono', monospace; font-size: 8px; letter-spacing: 0.1em; padding: 3px 8px; font-weight: 700; }
  .staff-photo .id { position: absolute; bottom: 10px; left: 10px; font-family: 'Oswald', sans-serif; font-size: 28px; color: rgba(236,228,214,0.1); }
  .staff-role { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--brass); letter-spacing: 0.1em; text-transform: uppercase; }
  .staff-name { font-family: 'Oswald', sans-serif; font-size: 22px; margin: 6px 0 10px; }
  .staff-bio { color: var(--ash); font-size: 12px; font-weight: 300; }

  @media (max-width: 900px) {
    .staff-grid { grid-template-columns: 1fr; }
  }
</style>

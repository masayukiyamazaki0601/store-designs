---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="BLACKSMITH ROASTERY | Brooklyn Style Coffee Roaster" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--black: #0a0908;
		--charcoal: #151311;
		--panel: #1d1916;
		--panel2: #242019;
		--brick: #7a3b26;
		--brick-bright: #b5502c;
		--copper: #c98a4b;
		--steel: #4a4642;
		--ash: #8d8579;
		--cream: #ece4d6;
		--cream-dim: #b8ae9d;
		--line: rgba(236,228,214,0.12);
		--line-strong: rgba(236,228,214,0.22);
	}
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}
	html {
		/* Lenisを使用するためscroll-behavior:smoothは外す */
		scroll-behavior: auto;
	}
	body {
		background: var(--black);
		color: var(--cream);
		font-family: 'Archivo', sans-serif;
		line-height: 1.6;
		overflow-x: hidden;
		cursor: none;
	}
	h1, h2, h3, .display {
		font-family: 'Anton', sans-serif;
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		line-height: 0.92;
	}
	.mono {
		font-family: 'JetBrains Mono', monospace;
		letter-spacing: 0.08em;
	}
	a {
		color: inherit;
		text-decoration: none;
	}
	img {
		max-width: 100%;
		display: block;
	}
	.wrap {
		max-width: 1240px;
		margin: 0 auto;
		padding: 0 32px;
	}
	::selection {
		background: var(--brick-bright);
		color: var(--black);
	}
</style>

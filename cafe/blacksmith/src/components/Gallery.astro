---
---
<section id="gallery">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <span class="tag">03 — INTERIOR</span>
        <h2>店内写真</h2>
      </div>
      <p class="head-note">配管、レンガ、鉄骨。無骨な素材がそのまま空間になっている。</p>
    </div>
    <div class="gallery-grid reveal">
      <div class="g-item g1"><img src="/images/gallery-1.jpg" alt="焙煎機" loading="lazy"><span>ROASTING FLOOR</span></div>
      <div class="g-item g2"><img src="/images/gallery-2.jpg" alt="レンガの壁の店内" loading="lazy"><span>BRICK WALL SEATING</span></div>
      <div class="g-item g3"><img src="/images/gallery-3.jpg" alt="配管" loading="lazy"><span>EXPOSED PIPING</span></div>
      <div class="g-item g4"><img src="/images/gallery-4.jpg" alt="バーカウンター" loading="lazy"><span>BAR COUNTER</span></div>
      <div class="g-item g5"><img src="/images/gallery-5.jpg" alt="生豆の袋" loading="lazy"><span>GREEN BEAN STORAGE</span></div>
      <div class="g-item g6"><img src="/images/gallery-6.jpg" alt="焙煎豆" loading="lazy"><span>ROASTED LOT</span></div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  document.addEventListener('astro:page-load', () => {
    gsap.registerPlugin(ScrollTrigger);

    // Gallery staggered entrance
    const grid = document.querySelector('.gallery-grid');
    if(grid) {
      ScrollTrigger.create({
        trigger: grid,
        start: 'top 85%',
        onEnter: () => {
          gsap.fromTo('.g-item', 
            { opacity: 0, scale: 0.95 },
            { opacity: 1, scale: 1, stagger: 0.1, duration: 0.8, ease: 'power3.out' }
          );
        }
      });
    }
  });
</script>

<style>
  section { position: relative; padding: 130px 0; border-bottom: 1px solid var(--line); }
  .section-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 64px; flex-wrap: wrap; gap: 24px; }
  .tag { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--copper); letter-spacing: 0.2em; margin-bottom: 14px; display: block; }
  .section-head h2 { font-size: clamp(36px, 5.4vw, 60px); }
  .head-note { max-width: 340px; color: var(--ash); font-size: 14px; }

  /* gallery bento */
  .gallery-grid { display: grid; grid-template-columns: repeat(6, 1fr); grid-auto-rows: 150px; gap: 12px; }
  .g-item { background: var(--panel); border: 1px solid var(--line); position: relative; overflow: hidden; display: flex; align-items: flex-end; padding: 16px; }
  .g-item img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .7s ease, filter .5s ease; filter: grayscale(45%) contrast(1.05); }
  .g-item:hover img { transform: scale(1.08); filter: grayscale(0%) contrast(1.05); }
  .g-item::before { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(10,9,8,0) 40%, rgba(10,9,8,0.9) 100%); z-index: 1; }
  .g-item span { position: relative; z-index: 2; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--cream); letter-spacing: 0.06em; }
  .g1 { grid-column: span 2; grid-row: span 2; }
  .g2 { grid-column: span 2; }
  .g3 { grid-column: span 2; }
  .g4 { grid-column: span 2; }
  .g5 { grid-column: span 2; grid-row: span 2; }
  .g6 { grid-column: span 2; }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .g1, .g2, .g3, .g4, .g5, .g6 { grid-column: span 1; }
    .g1, .g5 { grid-row: span 2; }
  }
</style>
